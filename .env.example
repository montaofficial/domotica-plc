# ─────────────────────────────────────────────────────────────────────────
# Domotica PLC — example environment file
#
# Copy this file to `.env` and fill in the real values.
#
#     cp .env.example .env
#
# The `.env` file is git-ignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────


# ── KNX gateway ──────────────────────────────────────────────────────────

# IP address of the KNX/IP gateway on your LAN (KNX-IP router or interface).
KNX_GATEWAY_IP=192.168.1.10

# Gateway port (default 3671, KNX/IP standard).
KNX_GATEWAY_PORT=3671

# Local IP the controller should bind to when talking to the gateway.
# Leave empty to auto-detect. Set this if the host has multiple NICs
# and you need to force the one on the KNX subnet (e.g. when running
# Docker with `network_mode: host`).
KNX_LOCAL_IP=

# knxultimate log level: error | warn | info | debug | trace
KNX_LOGLEVEL=info


# ── HTTP server ──────────────────────────────────────────────────────────

# Port the Node.js server listens on for HTTP + WebSocket.
PORT=3000

# `development` enables verbose error messages in responses.
# Set to `production` on the server.
NODE_ENV=production

# Comma-separated list of allowed CORS origins (used when the SPA is hosted
# on a different domain than the API). Leave empty for same-origin only.
# Example: https://domotica.example.com,https://lan.example.com
CORS_ORIGIN=


# ── Authentication ───────────────────────────────────────────────────────

# Single-user login for the web UI.
AUTH_USERNAME=admin

# Plaintext password used to log in. Pick something strong.
# Stored only in this file — never committed.
AUTH_PASSWORD=change-me-please

# Secret used to sign JWT session tokens. Must be at least 32 chars and
# must NOT be one of the example placeholders. Generate one with:
#
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# In production the server refuses to start without a real value here.
SESSION_SECRET=replace-with-output-of-the-command-above
