{
  "name": "domotica-plc",
  "version": "1.0.0",
  "description": "KNX home & office automation controller with realtime web UI",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "client:install": "cd client && npm install",
    "build": "npm run client:install && npm run client:build",
    "postinstall": "echo 'Tip: run npm run build to install + build the React client.'"
  },
  "keywords": [
    "knx",
    "home-automation",
    "smart-home",
    "domotica",
    "plc",
    "iot"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "knxultimate": "^5.5.8",
    "uuid": "^11.1.1",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  }
}
