# Development Dockerfile with hot reload support
FROM node:22-alpine

# Build dependencies for better-sqlite3.
RUN apk add --no-cache python3 make g++

WORKDIR /app

COPY package*.json ./
COPY client/package*.json ./client/

RUN npm install
RUN cd client && npm install

COPY server/ ./server/
COPY client/ ./client/

RUN mkdir -p /app/data

ENV NODE_ENV=development
ENV PORT=3000

EXPOSE 3000 5173

# Backend in watch mode + Vite dev server.
CMD ["sh", "-c", "npm run dev & cd client && npm run dev -- --host 0.0.0.0"]
